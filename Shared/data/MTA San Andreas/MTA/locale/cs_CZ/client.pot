#: Client/loader/MainFunctions.cpp:655
msgid "Are you having problems running MTA:SA?.\n\n"
"Do you want to see some online help?"
msgstr "Máš problémy se spouštěním MTA:SA?.\n\n"
"Chceš se podívat na online pomoc?"

#. Inform user
#: Client/loader/MainFunctions.cpp:692
msgid "Are you having problems running MTA:SA?.\n\n"
"Do you want to change the following setting?"
msgstr "Máte problémy se spuštěním MTA:SA?\n\n"
"Chcete změnit následující nastavení?"

#: Client/loader/MainFunctions.cpp:693 Client/core/CSettings.cpp:1161
