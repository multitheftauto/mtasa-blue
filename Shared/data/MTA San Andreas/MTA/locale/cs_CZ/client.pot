msgstr "Okno bez okraje"

#: Client/loader/MainFunctions.cpp:762
msgid "Are you having problems running MTA:SA?.\n\n"
"Try disabling the following products for GTA and MTA:"
msgstr "Máte problémy se spuštěním MTA:SA?\n\n"
"Zkuste vypnout následující programy pro GTA a MTA:"

#: Client/loader/MainFunctions.cpp:797
msgid "WARNING\n\n"
"MTA:SA has detected unusual activity.\n"
"Please run a virus scan to ensure your system is secure.\n\n"
msgstr "VAROVÁNÍ\n\n"
"MTA:SA zaznamenalo neobvyklou aktivitu.\n"
"Zapněte, prosím, virový sken, abyste se ujistili, že je váš systém v bezpečí.\n\n"

#: Client/loader/MainFunctions.cpp:800
#, c-format
msgid "The detected file was:  %s\n"
msgstr "Odhalený soubor:  %s\n"

#: Client/loader/MainFunctions.cpp:1047
msgid "An instance of GTA: San Andreas is already running. It needs to be terminated before MTA:SA can be started. Do you want to do that now?"
msgstr "Instance GTA: San Andreas již běží. Je zapotřebí ji terminovat před spuštěním MTA:SA. Chceš to udělat nyní?"

#: Client/loader/MainFunctions.cpp:1054
msgid "Unable to terminate GTA: San Andreas. If the problem persists, please restart your computer."
msgstr "Nelze ukončit GTA: San Andreas. Pokud problém přetrvává, zkus zrestartovat tvůj počítač."

#: Client/loader/MainFunctions.cpp:1188
msgid "Trouble restarting MTA:SA\n\n"
"If the problem persists, open Task Manager and\n"
"stop the 'gta_sa.exe' and 'Multi Theft Auto.exe' processes\n\n\n"
"Try to launch MTA:SA again?"
msgstr "Potíže při restartování MTA:SA\n\n"
"Pokud problém přetrvává, otevři správce úloh a\n"
"ukonči procesy 'gta_sa.exe' a 'Multi Theft Auto.exe'\n\n\n"
"Zkusit znovu spustit MTA:SA?"

