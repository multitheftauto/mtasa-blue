#: Client/loader/MainFunctions.cpp:1616
#, c-format
msgid "Load failed. %s exists in the GTA directory. Please delete before continuing."
msgstr "Fallo al cargar. %s existe en el directorio de GTA. Por favor elimínelo antes de continuar."

#: Client/loader/MainFunctions.cpp:1626
#, c-format
msgid "Main file has an incorrect name (%s)"
msgstr "El archivo principal contiene un nombre incorrecto (%s)"

#: Client/loader/MainFunctions.cpp:1668
#, c-format
